generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  HR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(HR)
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedCandidates       Candidate[]           @relation("HiringManager")
  recruitedCandidates     Candidate[]           @relation("Recruiter")
  managerAvailabilities   ManagerAvailability[]
  appointments            Appointment[]
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidates              Candidate[]
  managerAvailabilities   ManagerAvailability[]
  appointments            Appointment[]
}

model Candidate {
  id                String    @id @default(cuid())
  postingName       String
  location          String
  candidateName     String
  phone             String?
  dateApplied       String?
  hiringManager     String?
  recruiter         String?
  status            String    @default("pending")
  receivedAt        DateTime?
  emailId           String    @unique
  aiScore           Float?
  aiRecommendation  String?
  aiCriteriaMet     String?
  aiCriteriaMissing String?
  aiSummary         String?
  reviewedAt        DateTime?
  called            String?
  transcript        String?   @db.Text
  resumeUrl         String?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  locationId      String?
  hiringManagerId String?
  recruiterId     String?

  location_rel  Location? @relation(fields: [locationId], references: [id])
  hiringManager User?     @relation("HiringManager", fields: [hiringManagerId], references: [id])
  recruiter     User?     @relation("Recruiter", fields: [recruiterId], references: [id])

  @@index([status])
  @@index([location])
  @@index([locationId])
  @@index([postingName])
  @@index([emailId])
  @@index([deletedAt])
  @@index([hiringManagerId])
  @@index([recruiterId])
}

model ManagerAvailability {
  id           String   @id @default(cuid())
  location     String
  managerName  String
  managerEmail String
  dayOfWeek    String
  startTime    String
  endTime      String
  slotDuration String   @default("20 Min")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  locationId String?
  managerId  String?

  location_rel Location? @relation(fields: [locationId], references: [id])
  manager      User?     @relation(fields: [managerId], references: [id])

  @@index([location])
  @@index([locationId])
  @@index([managerId])
  @@index([dayOfWeek])
}

model Appointment {
  id            String   @id @default(cuid())
  location      String
  managerName   String?
  managerEmail  String?
  candidateName String
  jobRole       String?
  interviewDate DateTime
  day           String?
  startTime     String
  endTime       String
  slotDuration  String   @default("20 min")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  locationId String?
  managerId  String?

  location_rel Location? @relation(fields: [locationId], references: [id])
  manager      User?     @relation(fields: [managerId], references: [id])

  @@index([interviewDate])
  @@index([location])
  @@index([locationId])
  @@index([managerId])
  @@index([managerEmail])
}
