generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id    String @id @default(cuid())
  name  String
  email String @unique

  // Relations
  appointments          Appointment[]         @relation("ManagerAppointments")
  managerAvailabilities ManagerAvailability[] @relation("ManagerAvailabilityRelation")
}

model Location {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)

  // Relations
  appointments          Appointment[]
  managerAvailabilities ManagerAvailability[]
}

model Appointment {
  id              String   @id @default(cuid())
  candidateName   String
  interviewDate   DateTime
  startTime       String
  endTime         String?
  slotDuration    String

  // ✅ RELATIONS (match your code)
  location_rel   Location @relation(fields: [locationId], references: [id])
  locationId     String

  manager_rel    User?    @relation("ManagerAppointments", fields: [managerId], references: [id])
  managerId      String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ManagerAvailability {
  id           String   @id @default(cuid())
  dayOfWeek    String
  startTime    String
  endTime      String
  slotDuration String
  active       Boolean

  // ✅ RELATIONS (match your code)
  location_rel   Location @relation(fields: [locationId], references: [id])
  locationId     String

  manager_rel    User     @relation("ManagerAvailabilityRelation", fields: [managerId], references: [id])
  managerId      String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
