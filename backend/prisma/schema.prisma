generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  HR
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(HR)
  passwordHash String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  managedCandidates     Candidate[]           @relation("HiringManager")
  managerAvailabilities ManagerAvailability[]
  appointments          Appointment[]
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidates            Candidate[]
  managerAvailabilities ManagerAvailability[]
  appointments          Appointment[]
}

model Posting {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidates Candidate[]
}

model Candidate {
  id                String    @id @default(cuid())
  candidateName     String
  phone             String?
  dateApplied       String?
  status            String    @default("pending")
  receivedAt        DateTime?
  emailId           String    @unique
  aiScore           Float?
  aiRecommendation  String?
  aiCriteriaMet     String?
  aiCriteriaMissing String?
  aiSummary         String?
  reviewedAt        DateTime?
  called            String?
  transcript        String?   @db.Text
  resumeUrl         String?
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Foreign keys - REQUIRED
  postingId       String
  locationId      String
  hiringManagerId String?

  // Relations
  posting           Posting   @relation(fields: [postingId], references: [id])
  location          Location  @relation(fields: [locationId], references: [id])
  hiringManager     User?     @relation("HiringManager", fields: [hiringManagerId], references: [id])

  // Backward compatibility fields (can be removed after full migration)
  postingName   String? // Deprecated - use posting relation
  hiringManager_text String? @map("hiringManager") // Deprecated - use hiringManager relation

  @@index([status])
  @@index([locationId])
  @@index([postingId])
  @@index([postingName]) // Remove after migration
  @@index([emailId])
  @@index([deletedAt])
  @@index([hiringManagerId])
}

model ManagerAvailability {
  id           String   @id @default(cuid())
  dayOfWeek    String
  startTime    String
  endTime      String
  slotDuration String   @default("20 Min")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Foreign keys - REQUIRED
  locationId String
  managerId  String

  // Relations
  location Location @relation(fields: [locationId], references: [id])
  manager  User     @relation(fields: [managerId], references: [id])
  @@index([locationId])
  @@index([managerId])
  @@index([dayOfWeek])
}

model Appointment {
  id            String   @id @default(cuid())
  candidateName String
  jobRole       String?
  interviewDate DateTime
  day           String?
  startTime     String
  endTime       String
  slotDuration  String   @default("20 min")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Foreign keys - REQUIRED
  locationId String
  managerId  String?

  // Relations
  location Location @relation(fields: [locationId], references: [id])
  manager  User?    @relation(fields: [managerId], references: [id])

  @@index([interviewDate])
  @@index([locationId])
  @@index([managerId])
}
