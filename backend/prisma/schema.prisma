generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  HR
  MANAGER
}

model User {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  passwordHash String?
  role         Role   @default(HR)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())

  appointments          Appointment[]         @relation("ManagerAppointments")
  managerAvailabilities ManagerAvailability[] @relation("ManagerAvailabilityRelation")

  locations           Location[]

  hiringCandidates    Candidate[] @relation("HiringManager")
  recruitedCandidates Candidate[] @relation("Recruiter")
  notifications       Notification[]
  aygFoodsEmployees   AygFoodsEmployee[] @relation("ManagerAygFoodsEmployees")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("appointment_booked")
  title     String
  body      String
  read      Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Location {
  id       String  @id @default(cuid())
  name     String  @unique
  address  String?
  isActive Boolean @default(true)

  // ✅ Manager assigned to this location
  managerId String?
  manager   User?   @relation(fields: [managerId], references: [id], onDelete: SetNull)

  appointments          Appointment[]
  managerAvailabilities ManagerAvailability[]
  candidates            Candidate[]
  aygFoodsEmployees     AygFoodsEmployee[]
}

model Posting {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  candidates Candidate[]
}

model Candidate {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  dateApplied   String?
  status        String   @default("pending")
  emailId       String   @unique
  resumeUrl     String?

  // AI review fields (populated by n8n after Claude analysis)
  aiScore           Float?
  aiRecommendation  String?
  aiCriteriaMet     String?
  aiCriteriaMissing String?
  aiSummary         String?

  // Call transcript + recording (populated by n8n after Vapi call)
  transcript        String?
  recordingUrl      String?

  // Interview answers as JSON array [{question, category, answer}]
  interviewAnswers  String?

  // Outbound call metadata (set by n8n / Vapi)
  endedReason       String?    // VAPI ended-reason: voicemail, hangup, silence-timed-out, etc.
  nextCallAt        DateTime?  // Cooldown expiry — null means call anytime; set to now+1h on voicemail
  lastCallAt        DateTime?  // Timestamp of the most recent call attempt

  // Appointment cancellation
  cancelReason      String?
  cancelledAt       DateTime?

  posting_rel     Posting  @relation(fields: [postingId], references: [id])
  postingId       String

  location_rel    Location @relation(fields: [locationId], references: [id])
  locationId      String

  hiringManager_rel User?  @relation("HiringManager", fields: [hiringManagerId], references: [id])
  hiringManagerId   String?

  recruiter_rel    User?   @relation("Recruiter", fields: [recruiterId], references: [id])
  recruiterId      String?

  appointment      Appointment?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Appointment {
  id            String   @id @default(cuid())

  candidate_rel Candidate @relation(fields: [candidateId], references: [id])
  candidateId   String   @unique

  interviewDate DateTime
  startTime     String
  endTime       String?
  slotDuration  String

  location_rel Location @relation(fields: [locationId], references: [id])
  locationId   String

  manager_rel  User?    @relation("ManagerAppointments", fields: [managerId], references: [id])
  managerId    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ManagerAvailability {
  id           String   @id @default(cuid())
  dayOfWeek    String
  startTime    String
  endTime      String
  slotDuration String
  active       Boolean

  location_rel Location @relation(fields: [locationId], references: [id])
  locationId   String

  manager_rel  User     @relation("ManagerAvailabilityRelation", fields: [managerId], references: [id])
  managerId    String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AygFoodsEmployee {
  id                String    @id @default(cuid())
  revelId           Int       @unique
  firstName         String
  lastName          String
  email             String?
  phone             String?
  employeeStart     DateTime?
  isActive          Boolean   @default(true)
  establishmentId   Int
  establishmentName String?

  locationId        String?
  location          Location? @relation(fields: [locationId], references: [id])

  managerId         String?
  manager           User?     @relation("ManagerAygFoodsEmployees", fields: [managerId], references: [id])

  called            Boolean   @default(false)
  calledAt          DateTime?

  review            OnboardingReview?

  syncedAt          DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model OnboardingReview {
  id          String   @id @default(cuid())

  employeeId  String   @unique
  employee    AygFoodsEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  reviewType  String?  // e.g. "30_day"

  // Q1 — How are you finding your role so far?
  q1Rating    Int?
  q1Notes     String?

  // Q2 — Do you feel you have received adequate training and support?
  q2Rating    Int?
  q2Notes     String?

  // Q3 — Are there any aspects of the job that have surprised you?
  q3Notes     String?

  // Q4 — How do you feel about the team dynamics and company culture?
  q4Rating    Int?
  q4Notes     String?

  // Q5 — What have you accomplished so far?
  q5Notes     String?

  // Q6 — Is there anything you feel you need more clarity on?
  q6Notes     String?

  // Q7 — How can we support you better?
  q7Notes     String?

  overallNotes  String?

  // VAPI / n8n call data
  transcript    String?
  recordingUrl  String?
  callStatus    String?
  answers       String?  // raw JSON array from VAPI

  reviewedAt    DateTime @default(now())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
