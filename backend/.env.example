# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/hr_system"

# ─── Azure AD (JWT verification) ───────────────────────────────────────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_JWKS_URI=https://login.microsoftonline.com/your-tenant-id-here/discovery/v2.0/keys

# ─── n8n / Vapi API Key ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
N8N_API_KEY=generate-a-long-random-secret-here-min-32-chars

# ─── App ────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost:3000
